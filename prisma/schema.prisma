generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Chapter {
  id           String   @id @default(uuid())
  title        String
  draftContent String   @db.Text
  proseContent String   @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}